# 1 & 4: Create/write and append string

with open("file.txt", "w") as f: f.write("Hello World\n")

with open("file.txt", "a") as f: f.write("Appended line\n")

# 2: Read entire file

with open("file.txt", "r") as f: print(f.read())

# 3: Read line by line

with open("file.txt", "r") as f: for line in f: print(line.strip())

